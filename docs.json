{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Orca",
  "description": "Build, run, and publish AI agents with Orca.",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#FF775C",
    "light": "#CC4B32",
    "dark": "#FF775C"
  },
  "fonts": {
    "family": "Switzer",
    "heading": {
      "family": "Switzer",
      "weight": 600
    },
    "body": {
      "family": "Switzer",
      "weight": 400
    }
  },
  "topbar": {
    "links": [
      {
        "name": "CLI",
        "url": "https://github.com/okikorg/orca-cli"
      },
      {
        "name": "GitHub",
        "url": "https://github.com/okikorg"
      }
    ],
    "primary": {
      "name": "Get started",
      "url": "/quickstart"
    }
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/okikorg"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "get-started/create-an-agent",
              "get-started/stream-a-run"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/agents",
              "concepts/runs-and-sessions",
              "concepts/tools-skills-and-mcp",
              "concepts/memory-and-storage",
              "concepts/published-agents"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/integrate-orca",
              "guides/published-chat",
              "guides/workflows",
              "guides/use-cases",
              "guides/authentication",
              "guides/errors-and-events"
            ]
          }
        ]
      },
      {
        "tab": "CLI & SDKs",
        "groups": [
          {
            "group": "CLI",
            "pages": [
              "cli/overview",
              "cli/authentication",
              "cli/commands",
              "cli/agent-files"
            ]
          },
          {
            "group": "SDKs",
            "pages": [
              "sdk/overview",
              "sdk/typescript",
              "sdk/python",
              "sdk/go"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/control-plane",
              "api-reference/chat-gateway"
            ]
          },
          {
            "group": "Control Plane API",
            "openapi": "/api-reference/orca-openapi.yaml"
          },
          {
            "group": "Chat Gateway API",
            "openapi": "/api-reference/chat-openapi.yaml"
          }
        ]
      }
    ]
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "params": {
      "expanded": "all"
    },
    "examples": {
      "languages": ["curl", "javascript", "python", "go"],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    }
  }
}
